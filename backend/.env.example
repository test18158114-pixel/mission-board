# Production Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection
# Replace <username>, <password>, and cluster address with your Atlas credentials
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/mission_board?retryWrites=true&w=majority

# Upstash Redis Connection (for Socket.IO clustered horizontal sync)
# Format: rediss://default:<password>@<host>:<port>
REDIS_URI=

# Authorized CORS Origin (your deployed Vercel domain)
CORS_ORIGIN=https://your-frontend-domain.vercel.app
